#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel)"
cd "$ROOT_DIR"

if [[ -x backend/.venv/bin/pre-commit ]]; then
	exec backend/.venv/bin/pre-commit run --hook-stage pre-commit
fi

if command -v pre-commit >/dev/null 2>&1; then
	exec pre-commit run --hook-stage pre-commit
fi

echo "pre-commit is not installed. Install backend development dependencies first." >&2
exit 1
